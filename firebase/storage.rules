rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ---------- Helper functions ----------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // ---------- Videos ----------
    // Only admins can read/write; users get signed URLs from the server API

    match /videos/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024 * 1024; // 5 GB
    }

    // ---------- Thumbnails ----------
    // Admins can upload, anyone can read (public)

    match /thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 10 * 1024 * 1024 // 10 MB
        && request.resource.contentType.matches('image/.*');
    }

    // ---------- Banners ----------
    // Admins can upload, anyone can read (public)

    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 10 * 1024 * 1024 // 10 MB
        && request.resource.contentType.matches('image/.*');
    }

    // ---------- Site settings assets ----------
    // Logo + landing-page background. Admins upload (admin custom claim — Storage
    // rules can't read the Firestore role); anyone can read (shown publicly).

    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 15 * 1024 * 1024 // 15 MB
        && request.resource.contentType.matches('image/.*');
    }
  }
}
