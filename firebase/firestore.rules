rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && (
          request.auth.token.admin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Marketing staff OR admin — gates the marketing panel's data.
    function isMarketingStaff() {
      return isAuthenticated()
        && (
          request.auth.token.admin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "marketing"]
        );
    }

    // ---------- Users ----------

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Explicit list for admin collection queries (e.g. getCountFromServer)
      allow list: if isAdmin();

      // Create is separate from update: on a create `resource` is null, so
      // calling diff(resource.data) throws and the whole rule silently denies.
      // The original "allow write" lumped both together, which meant every
      // non-admin signup was rejected — new users never got a Firestore doc
      // even though their Auth record was created.
      //
      // Owners can self-create, but only with role="user" and a null
      // subscription so creation can't be used to grant admin/paid access.
      allow create: if isAdmin()
        || (
          isOwner(userId)
          && request.resource.data.role == "user"
          && (
            !("subscription" in request.resource.data)
            || request.resource.data.subscription == null
          )
        );

      // Owners can update everything except subscription + role.
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(["subscription", "role"]))
        );

      allow delete: if isAdmin();
    }

    // ---------- Content ----------

    match /content/{contentId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow create, update, delete: if isAdmin();

      match /videos/{videoId} {
        allow read: if isAuthenticated()
          && (
            get(/databases/$(database)/documents/content/$(contentId)).data.status == "published"
            || isAdmin()
          );
        allow create, update, delete: if isAdmin();
      }
    }

    // ---------- Plans ----------

    match /plans/{planId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ---------- Transactions ----------

    match /transactions/{txnId} {
      allow read: if isAdmin();
      allow write: if false; // Only server-side (admin SDK)
    }

    // ---------- Settings ----------

    match /settings/{settingId} {
      // Sensitive settings (secrets) are admin-only read
      // Public-readable settings: general, site
      // Admin-only settings: payment, payu, msg91
      allow read: if settingId in ["general", "site"] || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ---------- Analytics ----------

    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }

    // ---------- Marketing: Meta Pixels ----------

    match /pixels/{slug} {
      // Public-safe: { slug, pixelId, label, isDefault, adAccounts, hasToken }.
      // NO CAPI token here — the consumer site reads this to load the right pixel.
      allow read: if true;
      allow create, update, delete: if isMarketingStaff();
    }

    match /pixelSecrets/{slug} {
      // Server-only (CAPI access token). Never client-readable; admin SDK bypasses.
      allow read: if false;
      allow write: if isMarketingStaff();
    }

    // ---------- Marketing: purchase attribution (source per txn) ----------

    match /attributions/{txnId} {
      // Written server-side (admin SDK) at checkout + on purchase. Marketing
      // staff read it for the conversion analytics.
      allow read: if isMarketingStaff();
      allow write: if false;
    }

    // ---------- Marketing: daily rollups (scalable analytics) ----------

    match /marketingDaily/{date} {
      // Pre-aggregated per-IST-day COUNTS + CAPI. Server-written only
      // (aggregateMarketingDaily). Marketing staff + admin read it.
      allow read: if isMarketingStaff();
      allow write: if false;
    }

    match /marketingDailyRevenue/{date} {
      // Per-IST-day REVENUE. Server-written only. Admin-only (revenue split).
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
