rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated()
        && (
          request.auth.token.admin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ---------- Users ----------

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Explicit list for admin collection queries (e.g. getCountFromServer)
      allow list: if isAdmin();
      // Owners can write their own doc but NOT subscription or role fields
      allow write: if isAdmin()
        || (
          isOwner(userId)
          && (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(["subscription", "role"]))
        );
    }

    // ---------- Content ----------

    match /content/{contentId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow create, update, delete: if isAdmin();

      match /videos/{videoId} {
        allow read: if isAuthenticated()
          && (
            get(/databases/$(database)/documents/content/$(contentId)).data.status == "published"
            || isAdmin()
          );
        allow create, update, delete: if isAdmin();
      }
    }

    // ---------- Plans ----------

    match /plans/{planId} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ---------- Transactions ----------

    match /transactions/{txnId} {
      allow read: if isAdmin();
      allow write: if false; // Only server-side (admin SDK)
    }

    // ---------- Settings ----------

    match /settings/{settingId} {
      // Payment settings are admin-only; general settings are public read
      allow read: if settingId != "payment" || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ---------- Analytics ----------

    match /analytics/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
