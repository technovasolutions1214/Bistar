{
  "name": "novaflix",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@novaflix/web",
    "dev:admin": "turbo dev --filter=@novaflix/admin",
    "build:web": "turbo build --filter=@novaflix/web",
    "build:admin": "turbo build --filter=@novaflix/admin",
    "start:web": "turbo start --filter=@novaflix/web",
    "start:admin": "turbo start --filter=@novaflix/admin"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.33.0"
}
