# =============================================================================
# Bistar Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Firebase Web SDK Configuration ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=bistar-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=bistar-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=bistar-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin / Service Account ---
# Base64-encoded service account JSON (used in CI/CD)
FIREBASE_SERVICE_ACCOUNT=

# --- MSG91 OTP Service ---
NEXT_PUBLIC_MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# --- CDN ---
CDN_DOMAIN=cdn.bistar.app

# --- Firebase Project ID (for CLI / CI) ---
FIREBASE_PROJECT_ID=bistar-app
